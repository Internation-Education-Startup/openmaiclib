{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "../..",
    "baseUrl": "../..",
    "paths": { "@/*": ["./*"] }
  },
  "include": ["../../**/*.ts", "../../**/*.tsx"],
  "exclude": ["../../node_modules", "../../dist", "../../packages", "../../lib/ai/llm.ts", "../../lib/ai/thinking-context.ts", "../../lib/server/**", "../../lib/pdf/**", "../../lib/web-search/**"]
}
